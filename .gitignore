# =============================================================================
# Server Suite — .gitignore
# =============================================================================

# ----- NEVER commit these -----
secrets/
*.env
.env.*
*.key
*.pem
*.p12
*.pfx
config.json          # live server config contains paths/IPs/credentials
*.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
nosetests.xml
test-results/
tests/output/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# Build artefacts
*.deb
*.rpm
*.tar.gz
*.tar.bz2
*.zip
dist/
build/

# Runtime directories (created on the server, not in source)
logs/
scripts/          # generated at runtime per-server
backups/

# Docker volumes & compose overrides
docker-compose.override.yml
docker-compose.local.yml

# Temporary files
*.tmp
*.bak
*.orig
*.rej
/tmp/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
